# Only needed if you want to run the MCP server WITHOUT a config.toml — handy
# for a slim deploy that exposes Readeck as MCP and skips the Telegram bot.
# When you already keep a config.toml for the bot, the MCP can read the same
# file via `readeck-mcp -config config.toml`, and this .env is unused.

READECK_BASE_URL=https://read.example.com
READECK_API_TOKEN=rk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MCP_HTTP_ADDR=:8080
# If unset, the MCP endpoint is unauthenticated.
MCP_BEARER_TOKEN=
