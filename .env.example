# --- MCP server (single-tenant) ---
READECK_BASE_URL=https://read.example.com
READECK_API_TOKEN=rk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where the SSE endpoint listens. Behind a reverse proxy, leave at :8080.
MCP_HTTP_ADDR=:8080

# Optional. If set, the MCP HTTP endpoint requires "Authorization: Bearer <token>".
# Leave empty when the server is behind an authenticating reverse proxy.
MCP_BEARER_TOKEN=
